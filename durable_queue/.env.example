# 這份是設定清單的單一真相來源。settings.py 全部 no-default，
# 缺任何一個 → process 啟動即失敗（fail-fast）。複製成 .env 並填入實值。

# === Postgres ===
POSTGRES_DB=durable_queue
POSTGRES_USER=durable_queue
POSTGRES_PASSWORD=changeme

# === Worker & Django Api ===
# 本機直跑用 localhost；容器內由 compose 覆蓋成 postgres service name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# 本機直跑用 localhost；容器內由 compose 覆蓋成 redis service name
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Google OAuth 2.0 (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
