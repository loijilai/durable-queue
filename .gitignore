# Project-specific agent instructions


# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging
build/
dist/
*.egg-info/
.eggs/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Environment variables and local secrets
.env
.env.*
!.env.example

# Tests, coverage, and type checking
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.hypothesis/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo

# Operating system files
.DS_Store
Thumbs.db

# Terraform
# state 記錄真實 infra、可能含敏感值 → 不進版控（之後上 team 才換 remote backend）
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# 注意：.terraform.lock.hcl 要「進」版控（它鎖 provider 版本，像 lock file），所以不列在這

# User-defined
schema.yml